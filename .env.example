# ===== REQUIRED (app will not start without these) =====

# APP_URL: The public URL where the app is hosted.
# Used for CORS origin, self-referential API calls, and billing redirects.
# Must match the actual deployment URL exactly.
APP_URL="https://your-domain.com"

# ENCRYPTION_KEY: 64-character hex string (256-bit) for AES-256-GCM encryption of WordPress passwords.
# Generate one:  openssl rand -hex 32
# ⚠️  MUST be unique per deployment. Never use the same key across environments.
ENCRYPTION_KEY="CHANGE_ME_TO_64_CHAR_HEX_openssl_rand_hex_32"

# JWT_SECRET: Secret for HMAC signing of billing webhook events.
# Use a strong random string of 20+ characters.
# ⚠️  MUST be unique per deployment.
JWT_SECRET="CHANGE_ME_TO_A_STRONG_RANDOM_SECRET_20_PLUS_CHARS"


# ===== REQUIRED ONLY IF USING THAT FEATURE =====

# GEMINI_API_KEY: Google AI API key for Gemini-based SEO generation.
# Set this if you want AI-powered title/meta/alt-text generation using Gemini.
GEMINI_API_KEY=""

# OPENAI_API_KEY: OpenAI API key for OpenAI-based SEO generation.
# Set this if you want AI generation via OpenAI as an alternative or fallback.
OPENAI_API_KEY=""

# DATABASE_URL: PostgreSQL connection string for Prisma.
# If not set, the app falls back to JSON file storage (NOT concurrency-safe).
# Example: postgresql://user:password@host:5432/rankflow?schema=public
DATABASE_URL=""

# STRIPE_SECRET_KEY: Stripe secret key for payment processing.
# Required for the billing/upgrade and billing/webhook endpoints to work.
STRIPE_SECRET_KEY=""

# STRIPE_WEBHOOK_SECRET: Stripe webhook signing secret.
# Required to verify incoming Stripe webhook events.
STRIPE_WEBHOOK_SECRET=""


# ===== DEVELOPMENT ONLY (optional) =====

# PORT: Internal port the Express server listens on.
# Defaults to 3000 if not set. Must match the container's EXPOSE port.
PORT=3000

# NODE_ENV: Set to "production" for production deployments.
# In non-production, sandbox billing routes are enabled for testing.
NODE_ENV=production